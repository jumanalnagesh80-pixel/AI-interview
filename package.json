{
  "name": "ai-interview-prep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "backend:install": "cd backend && python3 -m pip install -r requirements.txt",
    "backend:dev": "cd backend && python3 -m uvicorn app.main:app --reload --port 8000",
    "backend:start": "cd backend && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000",
    "dev:all": "concurrently -n web,api -c magenta,cyan \"npm:dev\" \"npm:backend:dev\"",
    "start:all": "concurrently -n web,api -c magenta,cyan \"npm:start\" \"npm:backend:start\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.445.0",
    "next": "14.2.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.13",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
